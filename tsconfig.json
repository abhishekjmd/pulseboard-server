{
  "compilerOptions": {
    "target": "ES2020",
    "typeRoots": ["./node_modules/@types", "./types"],
    "module": "NodeNext",
    "moduleResolution": "nodenext",
    "esModuleInterop": true,
    "strict": false,
    "outDir": "./dist",
    "skipLibCheck": true,
    // "files": ["types/express.d.ts"] 
  },
  "include": ["**/*.ts", "types"],
  "exclude": ["node_modules", "dist"],
  "ts-node": {
    "files": true   // 👈 this is the key — forces ts-node to respect "files" and "include"
  }
}
